# Copy to .env (or set in your environment) to override defaults.
CMS_PORT=4000
MQTT_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
BASE_TOPIC=openframe
# A device is marked offline after this many ms without a heartbeat (3× the
# firmware's 30s heartbeat).
OFFLINE_TIMEOUT_MS=90000
# How long to wait for a /cmd/result ack before a command fails.
COMMAND_TIMEOUT_MS=10000
# Where the device snapshot is persisted.
DATA_DIR=./data
# Per-device rolling telemetry window (sparklines on the drill-in).
HISTORY_MAX_SAMPLES=720
# Alert thresholds.
ALERT_LOW_HEAP_BYTES=20000
ALERT_LOW_RSSI_DBM=-85
# If set, every alert (raise + resolve) is POSTed as JSON to this webhook.
# ALERT_WEBHOOK_URL=https://hooks.example.com/openframe
# If set, the API + dashboard require this shared token (Bearer header or login
# cookie). Leave unset for an open, LAN-trusted deployment.
# CMS_AUTH_TOKEN=change-me-to-a-long-random-string
# Base URL devices use to fetch OTA firmware from this CMS. REQUIRED to deploy
# firmware — it is never derived from the request Host header (that would be
# spoofable and could point the fleet at malicious firmware). Set it to this
# CMS's LAN address as the devices see it.
# CMS_PUBLIC_URL=http://192.168.1.50:4000
